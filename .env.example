# Copy this file to .env and fill in the values before running docker compose.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=

# Credentials for the admin account created on first boot
YAMS_ADMIN_USERNAME=admin
YAMS_ADMIN_PASSWORD=

# ── Modpack support ───────────────────────────────────────────────────────────

# CurseForge API key — get one free at https://console.curseforge.com/
# When set, CurseForge modpack search becomes available in addition to Modrinth.
# Modrinth always works with no configuration required.
#
# IMPORTANT: CurseForge API keys start with "$2a$" — wrap the value in SINGLE
# quotes so Docker Compose does not treat the dollar signs as variable references.
# Example:
# CURSEFORGE_API_KEY='$2a$10$your_full_key_here'

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to "false" to disable authentication entirely (local dev only, never in production)
# YAMS_AUTH_ENABLED=true

# Host port for the YAMS web UI (default: 3001).
# The container always listens internally on 3000; this maps it to the host.
# YAMS_PORT=3001

# 32-byte hex key for encrypting TOTP secrets at rest (optional, but recommended).
# Generate with: openssl rand -hex 32
# TOTP_ENCRYPTION_KEY=
