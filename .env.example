# Enable authentication
YAMS_AUTH_ENABLED=true

# Secret key for signing JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Initial admin account (created on first startup if no admin exists)
YAMS_ADMIN_EMAIL=admin@example.com
YAMS_ADMIN_PASSWORD=change-me-strong-password
