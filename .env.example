# Copy this file to .env and fill in the values before running docker compose.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=

# Credentials for the admin account created on first boot
YAMS_ADMIN_USERNAME=admin
YAMS_ADMIN_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to "false" to disable authentication entirely (local dev only, never in production)
# YAMS_AUTH_ENABLED=true

# HTTP port (default: 3000)
# PORT=3000

# Interface to listen on. 127.0.0.1 = localhost only (default, recommended).
# Set to 0.0.0.0 to expose on the network — use a TLS reverse proxy in that case.
# BIND_ADDRESS=127.0.0.1

# 32-byte hex key for encrypting TOTP secrets at rest (optional, but recommended).
# Generate with: openssl rand -hex 32
# TOTP_ENCRYPTION_KEY=
